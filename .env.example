# =============================================================================
# FinSolve AI Assistant — Environment Variables Template
# Copy this file to .env and fill in your values before starting the stack.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM — Groq API (LLaMA 3.1 70B)
# Get your key at: https://console.groq.com/
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Vector Database — Qdrant
# Local dev with backend on the host: uses the Qdrant Docker port on localhost
# Dockerized backend service overrides this to use the internal Docker hostname
# Staging/Prod: set to your Qdrant Cloud cluster URL + API key
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# Leave blank for local Docker
QDRANT_API_KEY=
QDRANT_COLLECTION=finsolve_docs

# -----------------------------------------------------------------------------
# Auth — JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_strong_random_secret_before_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# -----------------------------------------------------------------------------
# Redis — Session memory & rate limiting
# Local dev with backend on the host: uses the Redis Docker port on localhost
# Dockerized backend service overrides this to use the internal Docker hostname
# Staging/Prod: set to your ElastiCache endpoint
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# LangSmith — Observability & tracing (optional for local dev)
# Get your key at: https://smith.langchain.com/
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finsolve-chatbot
# Set to true to enable tracing
LANGCHAIN_TRACING_V2=false

# -----------------------------------------------------------------------------
# Embedding Model
# Default: sentence-transformers/all-MiniLM-L6-v2 (384-dim, no API cost)
# Set HF_TOKEN if Hugging Face rate limits apply or if you use gated/private models
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
HF_TOKEN=

# -----------------------------------------------------------------------------
# Prompt versioning
# Points to backend/app/rag/prompts/system_prompt_{PROMPT_VERSION}.txt
# -----------------------------------------------------------------------------
PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# Application
# ENVIRONMENT: local | staging | production
# -----------------------------------------------------------------------------
ENVIRONMENT=local

# -----------------------------------------------------------------------------
# Rate limiting (overrides per-role defaults if set)
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT_PER_HOUR=30
RATE_LIMIT_DEFAULT_PER_DAY=100
MAX_QUERY_LENGTH_CHARS=1000

# -----------------------------------------------------------------------------
# Data paths (used by ingestion pipeline)
# -----------------------------------------------------------------------------
DATA_DIR=../data
