# =============================================================================
# FinSolve AI Assistant — Environment Variables Template
# Copy this file to .env and fill in your values before starting the stack.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM provider selection
# Set LLM_PROVIDER to either `groq` or `ollama`.
# Only configure the env block for the provider you are actively using.
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq

# -----------------------------------------------------------------------------
# LLM — Groq API
# Get your key at: https://console.groq.com/
# -----------------------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0
GROQ_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# LLM — Ollama
# Ensure Ollama is running locally or reachable at OLLAMA_BASE_URL.
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=
OLLAMA_TEMPERATURE=0
OLLAMA_TIMEOUT_SECONDS=10

# -----------------------------------------------------------------------------
# Shared LLM retry policy
# -----------------------------------------------------------------------------
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_BACKOFF_SECONDS=2

# -----------------------------------------------------------------------------
# Vector Database — Qdrant
# Local dev with backend on the host: uses the Qdrant Docker port on localhost
# Dockerized backend service overrides this to use the internal Docker hostname
# Staging/Prod: set to your Qdrant Cloud cluster URL + API key
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
# Leave blank for local Docker
QDRANT_API_KEY=
QDRANT_COLLECTION=finsolve_docs

# -----------------------------------------------------------------------------
# Auth — JWT
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_strong_random_secret_before_production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=8

# -----------------------------------------------------------------------------
# Redis — Session memory & rate limiting
# Local dev with backend on the host: uses the Redis Docker port on localhost
# Dockerized backend service overrides this to use the internal Docker hostname
# Staging/Prod: set to your ElastiCache endpoint
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# LangSmith — Observability & tracing (optional for local dev)
# Get your key at: https://smith.langchain.com/
# -----------------------------------------------------------------------------
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=finsolve-chatbot
# Set to true to enable tracing
LANGCHAIN_TRACING_V2=false

# -----------------------------------------------------------------------------
# Embedding Model
# Default: sentence-transformers/all-MiniLM-L6-v2 (384-dim, no API cost)
# Set HF_TOKEN if Hugging Face rate limits apply or if you use gated/private models
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMS=384
HF_TOKEN=

# -----------------------------------------------------------------------------
# Prompt versioning
# Points to backend/app/rag/prompts/system_prompt_{PROMPT_VERSION}.txt
# -----------------------------------------------------------------------------
PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# Retrieval
# Controls the number of chunks returned from Qdrant and the minimum score kept
# -----------------------------------------------------------------------------
RETRIEVAL_TOP_K=20
RETRIEVAL_SCORE_THRESHOLD=0.55

# -----------------------------------------------------------------------------
# Query Transformation (all default off)
# ENABLE_QUERY_REWRITE  — HyDE: generate a hypothetical answer and embed that
# ENABLE_STEP_BACK      — rewrite as a broader question before retrieving
# ENABLE_MULTI_QUERY    — decompose into N sub-queries and merge results
# MULTI_QUERY_COUNT     — number of sub-queries to generate (default 3)
# -----------------------------------------------------------------------------
ENABLE_QUERY_REWRITE=false
ENABLE_STEP_BACK=false
ENABLE_MULTI_QUERY=false
MULTI_QUERY_COUNT=3

# -----------------------------------------------------------------------------
# Cross-Encoder Reranking (default off)
# ENABLE_RERANKING  — rerank Qdrant results with a cross-encoder before prompting
# RERANKER_MODEL    — HuggingFace model ID for the cross-encoder
# RERANKER_TOP_N    — chunks kept after reranking (should be ≤ RETRIEVAL_TOP_K)
# -----------------------------------------------------------------------------
ENABLE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=3

# -----------------------------------------------------------------------------
# Hybrid Search — BM25 sparse + dense RRF (off by default)
# ENABLE_HYBRID_SEARCH  — enable BM25 sparse vectors alongside dense retrieval
# BM25_MODEL            — fastembed model for sparse BM25 vectors
# HYBRID_PREFETCH_LIMIT_MULTIPLIER — each Prefetch arm fetches top_k * this
#
# IMPORTANT: Changing ENABLE_HYBRID_SEARCH requires full re-ingestion:
#   cd backend && uv run python -m ingest.ingest --reset
# After enabling, first run may download the BM25 ONNX model (~50 MB).
# -----------------------------------------------------------------------------
ENABLE_HYBRID_SEARCH=false
BM25_MODEL=Qdrant/bm25
HYBRID_PREFETCH_LIMIT_MULTIPLIER=2

# -----------------------------------------------------------------------------
# Structured Query Retrieval — for listing/filtering queries
# ENABLE_STRUCTURED_RETRIEVAL — enable Qdrant scroll-based retrieval for "list all X" queries
# Detects patterns like "List all Marketing Managers with locations" and fetches ALL matching
# HR records via scroll, bypassing semantic search limits. No re-ingestion required.
# Default: false (semantic-only retrieval)
# -----------------------------------------------------------------------------
ENABLE_STRUCTURED_RETRIEVAL=false

# -----------------------------------------------------------------------------
# Application
# ENVIRONMENT: local | staging | production
# -----------------------------------------------------------------------------
ENVIRONMENT=local
CORS_ALLOW_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# Rate limiting (overrides per-role defaults if set)
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT_PER_HOUR=30
RATE_LIMIT_DEFAULT_PER_DAY=100
RATE_LIMIT_FINANCE_PER_HOUR=50
RATE_LIMIT_ENGINEERING_PER_HOUR=50
RATE_LIMIT_EXECUTIVE_PER_HOUR=100
MAX_QUERY_LENGTH_CHARS=1000

# -----------------------------------------------------------------------------
# Health checks
# -----------------------------------------------------------------------------
HEALTH_REDIS_TIMEOUT_SECONDS=2

# -----------------------------------------------------------------------------
# Session memory and tracing
# -----------------------------------------------------------------------------
SESSION_HISTORY_MAX_MESSAGES=12
LANGSMITH_CHUNK_EXCERPT_MAX_CHARS=200

# -----------------------------------------------------------------------------
# Guardrails
# -----------------------------------------------------------------------------
INJECTION_SIMILARITY_THRESHOLD=0.85
SCOPE_SIMILARITY_THRESHOLD=0.05

# -----------------------------------------------------------------------------
# Cost monitoring — CloudWatch custom metrics (RC-143, RC-144)
# Groq LLaMA 3.3-70B pricing (USD per 1 000 tokens). Adjust when model changes.
# CLOUDWATCH_METRICS_ENABLED: set to true in staging/production ECS environments.
# -----------------------------------------------------------------------------
GROQ_COST_PER_1K_INPUT_TOKENS=0.00059
GROQ_COST_PER_1K_OUTPUT_TOKENS=0.00079
CLOUDWATCH_METRICS_ENABLED=false
CLOUDWATCH_NAMESPACE=FinSolveAI/TokenUsage
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Data paths (used by ingestion pipeline)
# -----------------------------------------------------------------------------
DATA_DIR=../data
